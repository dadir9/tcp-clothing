  </div>

</div>

{% stylesheet %}
  .size-guide-page {
    padding: 56px 40px 80px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .measure-section {
    margin-bottom: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
  }

  .measure-section h2,
  .size-table-section h2,
  .size-fit-tips h2 {
    font-size: 1.375rem;
    font-weight: 400;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }

  .measure-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media (max-width: 900px) {
    .measure-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .measure-grid {
      grid-template-columns: 1fr;
    }
  }

  .measure-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .measure-item__visual {
    color: var(--color-accent, #C2946B);
    width: 40px;
    height: 40px;
  }

  .measure-item h3 {
    font-size: 0.9375rem;
    font-weight: 500;
    margin: 0;
  }

  .measure-item p {
    font-size: 0.875rem;
    color: var(--color-muted, #8C8580);
    line-height: 1.65;
    margin: 0;
  }

  /* Size tables */
  .size-table-section {
    margin-bottom: 56px;
    padding-bottom: 56px;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
  }

  .size-note {
    font-size: 0.875rem;
    color: var(--color-muted, #8C8580);
    margin-bottom: 20px;
    font-style: italic;
  }

  .size-table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .size-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    min-width: 500px;
  }

  .size-table thead {
    background: var(--color-foreground, #141414);
    color: #FDF9F4;
  }

  .size-table th {
    padding: 12px 16px;
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    white-space: nowrap;
  }

  .size-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
    color: var(--color-foreground, #141414);
  }

  .size-table tbody tr:nth-child(even) td {
    background: var(--color-bg-subtle, #F7F3EF);
  }

  .size-table tbody tr:hover td {
    background: rgba(194, 148, 107, 0.07);
  }

  /* Fit tips */
  .size-fit-tips {
    margin-bottom: 56px;
    padding-bottom: 56px;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
  }

  .fit-tips-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 640px) {
    .fit-tips-grid {
      grid-template-columns: 1fr;
    }
  }

  .fit-tip {
    padding: 28px;
    border: 1px solid var(--color-border, #E8E2DC);
    border-radius: 2px;
  }

  .fit-tip h3 {
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 12px;
  }

  .fit-tip p {
    font-size: 0.875rem;
    color: var(--color-muted, #8C8580);
    line-height: 1.65;
    margin: 0;
  }

  .size-cta {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .size-cta p {
    font-size: 1rem;
    margin: 0;
  }
{% endstylesheet %}

