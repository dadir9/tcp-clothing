<section class="error-page">
  <div class="container">
    <span class="error-page__code">404</span>
    <h1 class="error-page__title">Page Not Found</h1>
    <p class="error-page__text">The page you're looking for doesn't exist or has been moved.</p>
    <div class="error-page__actions">
      <a href="{{ routes.root_url }}" class="btn btn--primary">BACK TO HOME</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">BROWSE PRODUCTS</a>
    </div>
  </div>
</section>

{% stylesheet %}
  .error-page {
    padding: 100px 0;
    text-align: center;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .error-page .container {
    max-width: 500px;
  }

  .error-page__code {
    font-size: 5rem;
    font-weight: 700;
    color: var(--color-light-gray);
    line-height: 1;
  }

  .error-page__title {
    font-size: 2rem;
    font-weight: 300;
    margin: 16px 0;
  }

  .error-page__text {
    color: var(--color-medium-gray);
    margin-bottom: 32px;
  }

  .error-page__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "404 Page",
  "settings": []
}
{% endschema %}
