<section class="hero full-width">
  <div class="hero__image-wrapper">
    {% if section.settings.image %}
      {{ section.settings.image | image_url: width: 1920 | image_tag: class: 'hero__image', loading: 'eager' }}
    {% else %}
      <div class="hero__placeholder"></div>
    {% endif %}
  </div>

  <div class="hero__content">
    <div class="hero__card">
      {% if section.settings.subtitle != blank %}
        <span class="hero__subtitle">{{ section.settings.subtitle }}</span>
      {% endif %}
      <h1 class="hero__title">{{ section.settings.title }}</h1>
      {% if section.settings.cta_text != blank %}
        <a href="{{ section.settings.cta_url }}" class="btn btn--primary hero__cta">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero {
    position: relative;
    height: 85vh;
    min-height: 500px;
    max-height: 800px;
    overflow: hidden;
  }

  .hero__image-wrapper {
    position: absolute;
    inset: 0;
  }

  .hero__image-wrapper img,
  .hero__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__placeholder {
    background: linear-gradient(135deg, #C2946B 0%, #8C8580 100%);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    height: 100%;
    padding: 0 80px;
  }

  .hero__card {
    background: rgba(255, 255, 255, 0.95);
    padding: 48px 56px;
    max-width: 420px;
    border-radius: 2px;
  }

  .hero__subtitle {
    display: block;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .hero__title {
    font-size: 2.25rem;
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 32px;
    color: var(--color-foreground);
  }

  .hero__cta {
    display: inline-flex;
  }

  @media (max-width: 768px) {
    .hero {
      height: 70vh;
      min-height: 400px;
    }

    .hero__content {
      padding: 0 20px;
      align-items: flex-end;
      padding-bottom: 40px;
    }

    .hero__card {
      padding: 32px;
      max-width: 100%;
    }

    .hero__title {
      font-size: 1.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "SUMMER 2025"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Mediterranean Collection"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "EXPLORE COLLECTION"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
