{% comment %}
  Contact Us page section — form + info
{% endcomment %}

<div class="info-page-header">
  <div class="page-container">
    <span class="section-label">Get in Touch</span>
    <h1>Contact Us</h1>
    <p class="info-page-header__lead">We aim to respond to all messages within 1 business day.</p>
  </div>
</div>

<div class="contact-page page-container">

  <div class="contact-grid">

    <div class="contact-form-col">
      <h2>Send us a message</h2>
      {%- form 'contact', id: 'ContactForm' -%}
        {%- if form.posted_successfully? -%}
          <div class="contact-success" role="status">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>Message sent — we'll be in touch soon.</span>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="contact-error" role="alert">
            <p>{{ form.errors | default_errors }}</p>
          </div>
        {%- endif -%}

        <div class="contact-form__row">
          <div class="form-field">
            <label for="ContactForm-name">Name <span aria-hidden="true">*</span></label>
            <input
              type="text"
              id="ContactForm-name"
              name="contact[name]"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              autocomplete="name"
              required
              placeholder="Your name"
            >
          </div>
        </div>

        <div class="form-field">
          <label for="ContactForm-email">Email <span aria-hidden="true">*</span></label>
          <input
            type="email"
            id="ContactForm-email"
            name="contact[email]"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            autocomplete="email"
            required
            placeholder="your@email.com"
          >
        </div>

        <div class="form-field">
          <label for="ContactForm-subject">Subject</label>
          <select id="ContactForm-subject" name="contact[subject]">
            <option value="">Select a topic</option>
            <option value="Order question">Order question</option>
            <option value="Shipping">Shipping</option>
            <option value="Returns">Returns &amp; Refunds</option>
            <option value="Product question">Product question</option>
            <option value="Sizing">Sizing help</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="form-field">
          <label for="ContactForm-order">Order number (optional)</label>
          <input
            type="text"
            id="ContactForm-order"
            name="contact[order_number]"
            placeholder="e.g. #1234"
          >
        </div>

        <div class="form-field">
          <label for="ContactForm-message">Message <span aria-hidden="true">*</span></label>
          <textarea
            id="ContactForm-message"
            name="contact[body]"
            rows="6"
            required
            placeholder="How can we help?"
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>

        <button type="submit" class="btn btn--primary contact-form__submit">
          Send Message
        </button>
      {%- endform -%}
    </div>

    <div class="contact-info-col">
      <div class="contact-info-block">
        <h3>Email</h3>
        <p><a href="mailto:hello@tcpclothing.com">hello@tcpclothing.com</a></p>
        <p class="contact-info-note">We respond within 1 business day (Mon–Fri, 9:00–17:00 CET).</p>
      </div>

      <div class="contact-info-block">
        <h3>Before You Write</h3>
        <p>Check our <a href="/pages/faq">FAQ</a> — you might find a quick answer there. Common topics:</p>
        <ul>
          <li><a href="/pages/faq#sizing">Sizing help</a></li>
          <li><a href="/pages/shipping">Shipping &amp; delivery times</a></li>
          <li><a href="/pages/faq#returns-faq">Returns &amp; refunds</a></li>
          <li><a href="/pages/faq#orders">Payment questions</a></li>
        </ul>
      </div>

      <div class="contact-info-block">
        <h3>Follow Us</h3>
        <div class="contact-social">
          <a href="https://www.instagram.com/tcpclothing1" target="_blank" rel="noopener" class="contact-social__link" aria-label="TCP Clothing on Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            Instagram
          </a>
          <a href="https://www.tiktok.com/@tcpclothing" target="_blank" rel="noopener" class="contact-social__link" aria-label="TCP Clothing on TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/></svg>
            TikTok
          </a>
          <a href="https://www.pinterest.com/tcpclothing1" target="_blank" rel="noopener" class="contact-social__link" aria-label="TCP Clothing on Pinterest">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.22-5.17 1.22-5.17s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.34.67 1.34 1.48 0 .9-.58 2.25-.87 3.5-.25 1.04.52 1.89 1.54 1.89 1.85 0 3.1-2.37 3.1-5.18 0-2.14-1.44-3.64-3.5-3.64-2.38 0-3.78 1.79-3.78 3.63 0 .72.28 1.49.62 1.91.07.08.08.15.06.24-.06.26-.2.82-.23.94-.04.15-.13.18-.3.11-1.12-.52-1.82-2.17-1.82-3.49 0-2.84 2.06-5.44 5.95-5.44 3.12 0 5.55 2.22 5.55 5.19 0 3.1-1.95 5.59-4.66 5.59-.91 0-1.77-.47-2.06-1.03l-.56 2.1c-.2.79-.75 1.77-1.12 2.37.84.26 1.74.4 2.67.4 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
            Pinterest
          </a>
        </div>
      </div>
    </div>

  </div>

</div>

{% stylesheet %}
  .contact-page {
    padding: 56px 40px 80px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 80px;
    align-items: flex-start;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  .contact-form-col h2 {
    font-size: 1.375rem;
    font-weight: 400;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }

  .contact-success {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    background: rgba(194, 148, 107, 0.1);
    border: 1px solid var(--color-accent, #C2946B);
    border-radius: 2px;
    color: var(--color-accent, #C2946B);
    font-size: 0.9375rem;
    margin-bottom: 24px;
  }

  .contact-error {
    padding: 16px 20px;
    background: rgba(200, 50, 50, 0.07);
    border: 1px solid rgba(200, 50, 50, 0.3);
    border-radius: 2px;
    font-size: 0.875rem;
    color: #c03030;
    margin-bottom: 24px;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 600px) {
    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 20px;
  }

  .form-field label {
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-foreground, #141414);
  }

  .form-field label span {
    color: var(--color-accent, #C2946B);
  }

  .form-field input,
  .form-field textarea,
  .form-field select {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--color-border, #E8E2DC);
    border-radius: 2px;
    background: var(--color-background, #FDF9F4);
    color: var(--color-foreground, #141414);
    font-size: 0.9375rem;
    line-height: 1.5;
    transition: border-color 0.15s ease;
  }

  .form-field input:focus,
  .form-field textarea:focus,
  .form-field select:focus {
    outline: none;
    border-color: var(--color-foreground, #141414);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 140px;
  }

  .contact-form__submit {
    margin-top: 8px;
    width: 100%;
  }

  /* Contact info column */
  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-top: 64px;
  }

  @media (max-width: 900px) {
    .contact-info-col {
      padding-top: 0;
    }
  }

  .contact-info-block h3 {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-accent, #C2946B);
    margin-bottom: 12px;
  }

  .contact-info-block p {
    font-size: 0.9375rem;
    color: var(--color-foreground, #141414);
    margin-bottom: 6px;
    line-height: 1.6;
  }

  .contact-info-block a {
    color: var(--color-accent, #C2946B);
    text-decoration: underline;
  }

  .contact-info-note {
    font-size: 0.8125rem !important;
    color: var(--color-muted, #8C8580) !important;
  }

  .contact-info-block ul {
    list-style: none;
    padding: 0;
    margin: 8px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-info-block ul li::before {
    content: '→ ';
    color: var(--color-accent, #C2946B);
  }

  .contact-info-block ul a {
    font-size: 0.9375rem;
  }

  .contact-social {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contact-social__link {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9375rem;
    color: var(--color-foreground, #141414);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .contact-social__link:hover {
    color: var(--color-accent, #C2946B);
  }

  .contact-social__link svg {
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Us",
  "settings": []
}
{% endschema %}
