<section class="trending" style="padding: var(--section-spacing) 0;">
  <div class="container">
    <div class="trending__header">
      <h2 class="trending__title">{{ section.settings.heading }}</h2>
      {% if section.settings.link_text != blank %}
        <a href="{{ section.settings.link_url }}" class="trending__view-all">{{ section.settings.link_text }} &rarr;</a>
      {% endif %}
    </div>

    <div class="trending__grid">
      {% if section.settings.collection != blank %}
        {% for product in collections[section.settings.collection].products limit: 4 %}
          <div class="product-card">
            <div class="product-card__image-wrapper">
              {% if product.featured_image %}
                <a href="{{ product.url }}">
                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                </a>
              {% endif %}

              <button class="product-card__wishlist" aria-label="Add to wishlist">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>

              {% if product.compare_at_price > product.price %}
                <span class="product-card__badge badge badge--sale">SALE</span>
              {% endif %}
            </div>

            <div class="product-card__info">
              <h3 class="product-card__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <div class="product-card__price">
                {% if product.compare_at_price > product.price %}
                  <span class="product-card__price--compare">{{ product.compare_at_price | money }}</span>
                  <span class="product-card__price--sale">{{ product.price | money }}</span>
                {% else %}
                  {{ product.price | money }}
                {% endif %}
              </div>
              {% if product.variants.size > 1 %}
                <div class="product-card__colors">
                  {% for variant in product.variants limit: 5 %}
                    {% if variant.option1 %}
                      <span class="product-card__color-dot" style="background-color: {{ variant.option1 | handleize }};" title="{{ variant.option1 }}"></span>
                    {% endif %}
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {%- comment -%} Placeholder products when no collection assigned {%- endcomment -%}
        {% for i in (1..4) %}
          <div class="product-card">
            <div class="product-card__image-wrapper">
              <div style="background: var(--color-light-gray); width: 100%; height: 100%;"></div>
              <button class="product-card__wishlist" aria-label="Add to wishlist">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
              </button>
              {% if i == 2 %}
                <span class="product-card__badge badge badge--sale">SALE</span>
              {% endif %}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title"><a href="#">Product Title {{ i }}</a></h3>
              <div class="product-card__price">
                {% if i == 2 %}
                  <span class="product-card__price--compare">&pound;89.00 / &euro;99.00</span>
                  <span class="product-card__price--sale">&pound;65.00 / &euro;75.00</span>
                {% else %}
                  &pound;65.00 / &euro;75.00
                {% endif %}
              </div>
              <div class="product-card__colors">
                <span class="product-card__color-dot" style="background-color: #141414;"></span>
                <span class="product-card__color-dot" style="background-color: #C2946B;"></span>
                <span class="product-card__color-dot" style="background-color: #F0ECEA;"></span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .trending__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .trending__title {
    font-weight: 300;
  }

  .trending__view-all {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: none;
    transition: color 0.2s;
  }

  .trending__view-all:hover {
    color: var(--color-accent);
  }

  .trending__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  @media (max-width: 960px) {
    .trending__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .trending__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trending Products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trending Now"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "View all text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "View all link"
    },
    {
      "type": "text",
      "id": "collection",
      "label": "Collection handle"
    }
  ],
  "presets": [
    {
      "name": "Trending Products"
    }
  ]
}
{% endschema %}
