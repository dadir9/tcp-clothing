<section class="newsletter full-width">
  <div class="newsletter__inner">
    <div class="container">
      <div class="newsletter__content">
        {% if section.settings.subtitle != blank %}
          <span class="newsletter__subtitle">{{ section.settings.subtitle }}</span>
        {% endif %}
        <h2 class="newsletter__title">{{ section.settings.title }}</h2>
        {% if section.settings.description != blank %}
          <p class="newsletter__description">{{ section.settings.description }}</p>
        {% endif %}

        {% form 'customer', class: 'newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter__form-group">
            <input
              type="email"
              name="contact[email]"
              placeholder="{{ section.settings.placeholder }}"
              class="newsletter__input"
              required
              autocomplete="email"
              aria-label="Email address"
            >
            <button type="submit" class="btn btn--accent newsletter__submit">
              {{ section.settings.button_text }}
            </button>
          </div>
          {% if form.posted_successfully? %}
            <p class="newsletter__success">Thank you for subscribing!</p>
          {% endif %}
          {% if form.errors %}
            <p class="newsletter__error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
          {% endif %}
        {% endform %}

        {% if section.settings.gdpr_text != blank %}
          <p class="newsletter__gdpr">{{ section.settings.gdpr_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .newsletter__inner {
    background-color: #141414;
    padding: 80px 0;
  }

  .newsletter__content {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter__subtitle {
    display: block;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .newsletter__title {
    font-size: 2rem;
    font-weight: 300;
    color: #FFFFFF;
    margin-bottom: 12px;
  }

  .newsletter__description {
    font-size: 0.875rem;
    color: #9A9A9A;
    margin-bottom: 32px;
  }

  .newsletter__form-group {
    display: flex;
    gap: 0;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter__input {
    flex: 1;
    padding: 14px 20px;
    background: #2A2A2A;
    border: 1px solid #3A3A3A;
    border-right: none;
    border-radius: 2px 0 0 2px;
    color: #FFFFFF;
    font-size: 0.8125rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .newsletter__input::placeholder {
    color: #666;
  }

  .newsletter__input:focus {
    border-color: var(--color-accent);
  }

  .newsletter__submit {
    border-radius: 0 2px 2px 0;
    white-space: nowrap;
    padding: 14px 28px;
  }

  .newsletter__success {
    margin-top: 16px;
    font-size: 0.8125rem;
    color: #4CAF50;
  }

  .newsletter__error {
    margin-top: 16px;
    font-size: 0.8125rem;
    color: #FF5252;
  }

  .newsletter__gdpr {
    margin-top: 16px;
    font-size: 0.6875rem;
    color: #666;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .newsletter__inner {
      padding: 48px 0;
    }

    .newsletter__form-group {
      flex-direction: column;
      gap: 12px;
    }

    .newsletter__input {
      border-right: 1px solid #3A3A3A;
      border-radius: 2px;
    }

    .newsletter__submit {
      border-radius: 2px;
    }

    .newsletter__title {
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "NEWSLETTER"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "JOIN THE TCP CLUB"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Get 10% Off Your First Order"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SUBSCRIBE"
    },
    {
      "type": "text",
      "id": "gdpr_text",
      "label": "GDPR text",
      "default": "By subscribing, you agree to our Privacy Policy and consent to receive updates from TCP Clothing."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
