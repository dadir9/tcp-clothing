{% comment %}
  Shipping & Returns page section
{% endcomment %}

<div class="info-page-header">
  <div class="page-container">
    <span class="section-label">Delivery &amp; Returns</span>
    <h1>Shipping &amp; Returns</h1>
    <p class="info-page-header__lead">We ship to the UK and across Europe. All orders are processed within 1–2 business days.</p>
  </div>
</div>

<div class="info-page-body page-container">

  <div class="info-section">
    <h2>Shipping by Region</h2>
    <div class="shipping-table">

      <div class="shipping-row shipping-row--header">
        <span>Market</span>
        <span>Carrier</span>
        <span>Standard</span>
        <span>Express</span>
        <span>Free Over</span>
      </div>

      <div class="shipping-row">
        <span><span class="flag">🇬🇧</span> United Kingdom</span>
        <span>Royal Mail / DPD</span>
        <span>3–5 days · £3.99</span>
        <span>1–2 days · £7.99</span>
        <span>£60+</span>
      </div>

      <div class="shipping-row">
        <span><span class="flag">🇫🇷</span> France</span>
        <span>Colissimo / DPD</span>
        <span>4–6 days · €4.99</span>
        <span>2–3 days · €8.99</span>
        <span>€70+</span>
      </div>

      <div class="shipping-row">
        <span><span class="flag">🇳🇱</span> Netherlands</span>
        <span>PostNL / DPD</span>
        <span>3–5 days · €4.99</span>
        <span>2–3 days · €8.99</span>
        <span>€70+</span>
      </div>

      <div class="shipping-row">
        <span><span class="flag">🇩🇪</span> Germany</span>
        <span>DPD</span>
        <span>4–6 days · €5.99</span>
        <span>2–3 days · €9.99</span>
        <span>€70+</span>
      </div>

      <div class="shipping-row">
        <span><span class="flag">🇧🇪</span> Belgium</span>
        <span>DPD</span>
        <span>4–6 days · €5.99</span>
        <span>2–3 days · €9.99</span>
        <span>€70+</span>
      </div>

      <div class="shipping-row">
        <span><span class="flag">🇪🇸</span> Spain · 🇮🇹 Italy</span>
        <span>DPD</span>
        <span>5–7 days · €6.99</span>
        <span>3–4 days · €11.99</span>
        <span>€80+</span>
      </div>

      <div class="shipping-row">
        <span><span class="flag">🇸🇪</span> Sweden · 🇩🇰 Denmark</span>
        <span>DPD</span>
        <span>5–7 days · from SEK 69 / DKK 49</span>
        <span>3–4 days</span>
        <span>SEK 700 / DKK 550</span>
      </div>

    </div>
    <p class="info-note">Delivery times are estimates from dispatch date, not order date. Tracking is included with all orders.</p>
  </div>

  <div class="info-section">
    <h2>Processing Times</h2>
    <ul class="info-list">
      <li>Orders placed before 14:00 (CET) are dispatched the same business day.</li>
      <li>Orders placed after 14:00 are dispatched the next business day.</li>
      <li>No dispatches on weekends or UK/EU public holidays.</li>
      <li>During sale periods, processing may take up to 3 business days.</li>
    </ul>
  </div>

  <div class="info-section">
    <h2>Returns Policy</h2>
    <div class="info-cards">
      <div class="info-card">
        <span class="info-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </span>
        <h3>14-Day Returns</h3>
        <p>Return any unworn, unwashed item in original condition within 14 days of delivery. EU customers have 14 days by law; we honour this across all markets.</p>
      </div>
      <div class="info-card">
        <span class="info-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        </span>
        <h3>Easy Exchanges</h3>
        <p>Want a different size or colour? Start a return and place a new order. We process refunds within 5 business days of receiving your item.</p>
      </div>
      <div class="info-card">
        <span class="info-card__icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </span>
        <h3>Faulty Items</h3>
        <p>Received something damaged or defective? Contact us within 7 days at <a href="mailto:hello@tcpclothing.com">hello@tcpclothing.com</a> and we'll sort it immediately.</p>
      </div>
    </div>
  </div>

  <div class="info-section">
    <h2>How to Return</h2>
    <ol class="info-steps">
      <li>
        <span class="step-number">01</span>
        <div>
          <strong>Email us</strong>
          <p>Send your order number and reason for return to <a href="mailto:hello@tcpclothing.com">hello@tcpclothing.com</a>.</p>
        </div>
      </li>
      <li>
        <span class="step-number">02</span>
        <div>
          <strong>Pack securely</strong>
          <p>Place items in their original packaging or a secure bag. Include your order confirmation inside.</p>
        </div>
      </li>
      <li>
        <span class="step-number">03</span>
        <div>
          <strong>Ship back</strong>
          <p>We'll send you the return address. Return shipping costs are the customer's responsibility unless the item is faulty.</p>
        </div>
      </li>
      <li>
        <span class="step-number">04</span>
        <div>
          <strong>Refund issued</strong>
          <p>Once received and inspected, your refund is issued to the original payment method within 5 business days.</p>
        </div>
      </li>
    </ol>
  </div>

  <div class="info-section">
    <h2>Non-Returnable Items</h2>
    <ul class="info-list">
      <li>Swimwear and underwear (for hygiene reasons, unless faulty)</li>
      <li>Items with removed tags or in a non-resaleable condition</li>
      <li>Final sale items marked as non-returnable at purchase</li>
    </ul>
  </div>

</div>

{% stylesheet %}
  .info-page-header {
    background: var(--color-background);
    padding: 80px 0 48px;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
  }

  .info-page-header h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 300;
    margin: 12px 0 20px;
    letter-spacing: -0.02em;
  }

  .info-page-header__lead {
    font-size: 1.0625rem;
    color: var(--color-muted, #8C8580);
    max-width: 560px;
    line-height: 1.7;
  }

  .info-page-body {
    padding: 64px 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .info-section {
    margin-bottom: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
  }

  .info-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .info-section h2 {
    font-size: 1.375rem;
    font-weight: 400;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }

  /* Shipping table */
  .shipping-table {
    border: 1px solid var(--color-border, #E8E2DC);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .shipping-row {
    display: grid;
    grid-template-columns: 2fr 1.5fr 2fr 2fr 1fr;
    gap: 16px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
    font-size: 0.875rem;
    align-items: center;
  }

  .shipping-row:last-child {
    border-bottom: none;
  }

  .shipping-row--header {
    background: var(--color-foreground, #141414);
    color: #FDF9F4;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .shipping-row:not(.shipping-row--header):nth-child(even) {
    background: var(--color-bg-subtle, #F7F3EF);
  }

  .flag {
    margin-right: 6px;
  }

  @media (max-width: 768px) {
    .shipping-row {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .shipping-row--header span:nth-child(n+3) {
      display: none;
    }
  }

  .info-note {
    font-size: 0.8125rem;
    color: var(--color-muted, #8C8580);
    font-style: italic;
  }

  /* Info list */
  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .info-list li {
    padding-left: 20px;
    position: relative;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-foreground);
  }

  .info-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent, #C2946B);
  }

  /* Info cards */
  .info-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 768px) {
    .info-cards {
      grid-template-columns: 1fr;
    }
  }

  .info-card {
    padding: 28px;
    border: 1px solid var(--color-border, #E8E2DC);
    border-radius: 2px;
  }

  .info-card__icon {
    display: flex;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    color: var(--color-accent, #C2946B);
    margin-bottom: 16px;
  }

  .info-card h3 {
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 10px;
  }

  .info-card p {
    font-size: 0.875rem;
    color: var(--color-muted, #8C8580);
    line-height: 1.65;
    margin: 0;
  }

  .info-card a {
    color: var(--color-accent, #C2946B);
    text-decoration: underline;
  }

  /* Steps */
  .info-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .info-steps li {
    display: flex;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border, #E8E2DC);
    align-items: flex-start;
  }

  .info-steps li:last-child {
    border-bottom: none;
  }

  .step-number {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--color-accent, #C2946B);
    min-width: 32px;
    padding-top: 2px;
  }

  .info-steps strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 6px;
  }

  .info-steps p {
    font-size: 0.875rem;
    color: var(--color-muted, #8C8580);
    margin: 0;
    line-height: 1.65;
  }

  .info-steps a {
    color: var(--color-accent, #C2946B);
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shipping & Returns",
  "settings": []
}
{% endschema %}
