<section class="collections-grid" style="padding: var(--section-spacing) 0;">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="collections-grid__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="collections-grid__items">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="collections-grid__card" {{ block.shopify_attributes }}>
          <div class="collections-grid__image-wrapper">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'collections-grid__image', loading: 'lazy' }}
            {% else %}
              <div class="collections-grid__placeholder"></div>
            {% endif %}
          </div>
          <div class="collections-grid__overlay">
            <span class="collections-grid__name">{{ block.settings.title }}</span>
            <span class="collections-grid__arrow">→</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .collections-grid__heading {
    text-align: center;
    margin-bottom: 40px;
    font-weight: 300;
  }

  .collections-grid__items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .collections-grid__card {
    position: relative;
    display: block;
    border-radius: 2px;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 3 / 4;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .collections-grid__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  }

  .collections-grid__image-wrapper {
    position: absolute;
    inset: 0;
  }

  .collections-grid__image-wrapper img,
  .collections-grid__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .collections-grid__card:hover .collections-grid__image-wrapper img {
    transform: scale(1.05);
  }

  .collections-grid__placeholder {
    background: var(--color-light-gray);
  }

  .collections-grid__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  }

  .collections-grid__overlay {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .collections-grid__name {
    color: #FFFFFF;
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .collections-grid__arrow {
    color: #FFFFFF;
    font-size: 1.25rem;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s ease;
  }

  .collections-grid__card:hover .collections-grid__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .collections-grid__items {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .collections-grid__card {
      aspect-ratio: 16 / 9;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collections Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Collection name",
          "default": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Grid",
      "blocks": [
        {
          "type": "collection_card",
          "settings": { "title": "Swimwear" }
        },
        {
          "type": "collection_card",
          "settings": { "title": "Linen Edit" }
        },
        {
          "type": "collection_card",
          "settings": { "title": "Festival Wear" }
        }
      ]
    }
  ]
}
{% endschema %}
